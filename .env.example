DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
WEB_CONCURRENCY=1
GUNICORN_TIMEOUT=180
CSV_CHUNK_SIZE=500
STAGED_FILE_CACHE_MAX_ITEMS=2
STAGED_FILE_CACHE_TTL_SECONDS=900
# Set STAGED_FILE_CACHE_MAX_ITEMS=0 to disable staged-file reuse.
# Set this only if you later attach a persistent disk on Render.
# DJANGO_SQLITE_PATH=/app/data/db.sqlite3
# Render injects PORT, RENDER_EXTERNAL_HOSTNAME, and RENDER_EXTERNAL_URL automatically.
PORT=8000
